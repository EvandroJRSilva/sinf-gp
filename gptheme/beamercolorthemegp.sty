% COLORS
%
% 	RED GRADIENT
% 		Night Bordeaux	#641220		100,18,32
% 		Burgundy		#6e1423		110,20,35
% 		Burgundy		#85182a		133,24,42
% 		Ruby Red		#a11d33		161,29,51
% 		Ruby Red		#a71e34		167,30,52
% 		Carmine			#b21e35		178,30,53
% 		Intense Cherry	#bd1f36		189,31,54
% 		Intense Cherry	#c71f37		199,31,55
% 		Classic Crimson	#da1e37		218,30,55
% 		Scarlet Rush	#e01e37		224,30,55
%
% 	FIERY HOT FLAMES
% 		Molten Lava		#7c0606		124,6,6
% 		Blood Red		#930505		147,5,5
% 		Inferno			#ab0404		171,4,4
% 		Brick Ember		#c20303		194,3,3
% 		Brick Ember		#d90202		217,2,2


\mode<presentation>

% Theme background
\definecolor{burgundy}{RGB}{133,24,42}
\definecolor{intensecherry}{RGB}{199,31,55}
\definecolor{bloodred}{RGB}{147,5,5}
\definecolor{block_color}{RGB}{0, 82, 155}

% Basic beamer colors
\setbeamercolor{normal text}{fg=black}
\setbeamercolor{alerted text}{fg=intensecherry}
\setbeamercolor{structure}{fg=bloodred}

% Title page
\setbeamercolor{title}{fg=white}
\setbeamercolor{subtitle}{fg=white}
\setbeamercolor{author}{fg=white}
\setbeamercolor{institute}{fg=white}
\setbeamercolor{date}{fg=white}

% Bloco normal
\setbeamercolor{block title}{use=structure,fg=white,bg=block_color}
\setbeamercolor{block body}{fg=black,use=block title,bg=block_color!10}

% Bloco de exemplo
\setbeamercolor{block title example}{use=example text,fg=white,bg=green!50!black}
\setbeamercolor{block body example}{use=block title example,fg=black,bg=green!10}

% Bloco de alerta
\setbeamercolor{block title alerted}{use=alerted text,fg=white,bg=burgundy}
\setbeamercolor{block body alerted}{fg=black,use=block title alerted,bg=burgundy!10}

% Itemize
\setbeamercolor{item}{fg=bloodred}

\mode
<all>


